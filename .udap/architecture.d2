# udap:meta cloud=aws region=us-east-1 target=ec2

developer: Developer { shape: rectangle; udap-type: generic.user }
cicd: GitHub Actions CI { shape: rectangle; udap-type: generic.app }
pipeline: Build Pipeline {
  lint: Lint & Kotlin Compile { shape: rectangle; udap-type: generic.app }
  test: Unit Tests (JUnit) { shape: rectangle; udap-type: generic.app }
  build: Build Debug APK { shape: rectangle; udap-type: generic.app }
  artifact: APK Artifact (GitHub) { shape: rectangle; udap-type: generic.app }
}
uitest: UI Test Pipeline {
  provision_ec2: Provision EC2 (t3.large) { shape: rectangle; udap-type: aws.ec2 }
  setup: Install Emulator + Maestro { shape: rectangle; udap-type: generic.app }
  run_tests: Run Maestro UI Tests { shape: rectangle; udap-type: generic.app }
  record: Screen Recording (adb) { shape: rectangle; udap-type: generic.app }
  artifacts: Video + Report Artifacts { shape: rectangle; udap-type: generic.app }
  destroy_ec2: Destroy EC2 { shape: rectangle; udap-type: aws.ec2 }
}
aws: AWS us-east-1 {
  ec2: Test Runner EC2 (t3.large) { shape: rectangle; udap-type: aws.ec2 }
  sg: Security Group { shape: rectangle; udap-type: generic.app }
}
app: Android Todo App (Kotlin) { shape: rectangle; udap-type: generic.app }
db: Room DB (SQLite) { shape: rectangle; udap-type: generic.db }

developer -> cicd: git push / PR
cicd -> pipeline.lint: trigger build
pipeline.lint -> pipeline.test: pass
pipeline.test -> pipeline.build: pass
pipeline.build -> pipeline.artifact: upload APK
cicd -> uitest.provision_ec2: workflow_dispatch
uitest.provision_ec2 -> aws.ec2: terraform apply
aws.sg -> aws.ec2: allow SSH
uitest.provision_ec2 -> uitest.setup: EC2 ready
uitest.setup -> uitest.run_tests: emulator booted
uitest.run_tests -> uitest.record: capture screen
uitest.record -> uitest.artifacts: upload video + report
uitest.artifacts -> uitest.destroy_ec2: teardown
uitest.destroy_ec2 -> aws.ec2: terraform destroy
app -> db: read/write todos
